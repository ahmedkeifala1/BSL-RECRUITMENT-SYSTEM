generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["omitApi"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EmploymentType {
  Full_Time
  Part_Time
  Contract
  Internship

  @@map("job_types")
}

model JobSeeker {
  id           String              @id @default(cuid())
  title        String
  firstName    String
  lastName     String
  middleName   String?
  fullName     String
  email        String              @unique
  account_id   String              @unique
  account      User                @relation(fields: [account_id], references: [id])
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  applications Application[]
  documents    JobSeekerDocument[]

  @@map("job_seekers")
}

enum UserStatus {
  Active
  Blocked
  Inactive

  @@map("user_statuses")
}

enum UserType {
  Admin
  Staff
  User

  @@map("user_types")
}

model User {
  id              String     @id @default(cuid())
  fullName        String
  email           String     @unique
  password        String
  userType        UserType   @default(User)
  isEmailVerified Boolean    @default(false)
  status          UserStatus @default(Active)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  details         JobSeeker?
  profile         Staff?

  @@map("users")
}

enum JobStatus {
  Drafted
  Approved
  Rejected

  @@map("job_statuses")
}

model Job {
  id          String         @id @default(cuid())
  title       String
  description String
  type        EmploymentType
  status      JobStatus      @default(Drafted)
  listings    JobListing[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  vacancies   Vacancy[]

  @@map("jobs")
}

enum JobListingType {
  Qualification
  Responsibility

  @@map("job_listing_types")
}

model JobListing {
  id           String         @id @default(cuid())
  name         String
  type         JobListingType
  requirements String[]
  jobId        String
  job          Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_listings")
}

enum VacancyStatus {
  Drafted
  Published
  Unpublished

  @@map("vacancy_statuses")
}

enum VacancyType {
  Internal
  External

  @@map("vacancy_types")
}

model Vacancy {
  id             String         @id @default(cuid())
  profession     String
  roleType       String
  employmentType EmploymentType
  type           VacancyType    @default(External)
  jobId          String
  job            Job            @relation(fields: [jobId], references: [id])
  status         VacancyStatus  @default(Drafted)
  postedAt       DateTime       @default(now())
  deadline       DateTime
  applicants     Application[]

  @@map("vacancies")
}

enum AdminRole {
  Admin
  Director
  Manager

  @@map("admin_roles")
}

model Admin {
  id       String    @id @default(cuid())
  role     AdminRole
  staff_id String    @unique
  staff    Staff     @relation(fields: [staff_id], references: [id])

  @@map("admins")
}

enum Gender {
  Female
  Male

  @@map("genders")
}

model Staff {
  id            String   @id @default(cuid())
  title         String
  firstName     String
  lastName      String
  middleName    String?
  fullName      String
  designation   String
  department    String
  division      String
  unit          String
  gender        Gender   @default(Male)
  email         String   @unique
  admin_details Admin?
  account_id    String   @unique
  account       User     @relation(fields: [account_id], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("staffs")
}

enum ApplicationStatus {
  Hired
  Reviewed
  Rejected
  Submitted
  Shortlisted

  @@map("application_statuses")
}

model Application {
  id            String                @id @default(cuid())
  status        ApplicationStatus     @default(Submitted)
  jobSeekerId   String
  jobSeeker     JobSeeker             @relation(fields: [jobSeekerId], references: [id])
  vacancyId     String
  vacancy       Vacancy               @relation(fields: [vacancyId], references: [id])
  cvId          String                @unique
  cv            JobSeekerDocument     @relation(fields: [cvId], references: [id])
  coverLetterId String                @unique
  coverLetter   Document              @relation(fields: [coverLetterId], references: [id])
  documents     ApplicationDocument[]

  @@map("applications")
}

model ApplicationDocument {
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  documentId    String
  document      Document    @relation(fields: [documentId], references: [id])

  @@id([applicationId, documentId])
  @@map("application_documents")
}

enum JobSeekerDocumentType {
  Curriculum_Vitae
  Certification
  Cover_Letter
  Identification
  Other

  @@map("job_seeker_document_types")
}

model JobSeekerDocument {
  id           String                @id @default(cuid())
  type         JobSeekerDocumentType
  jobSeekerId  String
  jobSeeker    JobSeeker             @relation(fields: [jobSeekerId], references: [id])
  documentId   String
  document     Document              @relation(fields: [documentId], references: [id])
  applications Application[]

  @@map("job_seeker_documents")
}

model Document {
  id           String                @id @default(cuid())
  name         String
  url          String
  type         String
  size         BigInt
  jobSeekers   JobSeekerDocument[]
  letters      Application[]
  applications ApplicationDocument[]

  @@map("documents")
}
