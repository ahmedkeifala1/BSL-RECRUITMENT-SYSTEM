generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["omitApi"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EmploymentType {
  Full_Time
  Part_Time
  Contract
  Internship

  @@map("job_types")
}

model JobSeeker {
  id         String   @id @default(cuid())
  title      String
  firstName  String
  lastName   String
  middleName String?
  fullName   String
  email      String   @unique
  account_id String   @unique
  account    User     @relation(fields: [account_id], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("job_seekers")
}

enum UserStatus {
  Active
  Blocked
  Inactive

  @@map("user_statuses")
}

enum UserType {
  Admin
  Staff
  User

  @@map("user_types")
}

model User {
  id              String     @id @default(cuid())
  fullName        String
  email           String     @unique
  password        String
  userType        UserType   @default(User)
  isEmailVerified Boolean    @default(false)
  status          UserStatus @default(Active)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  details         JobSeeker?
  profile         Staff?

  @@map("users")
}

enum JobStatus {
  Draft
  Approved
  Rejected

  @@map("job_statuses")
}

model Job {
  id          String         @id @default(cuid())
  title       String
  description String
  type        EmploymentType
  status      JobStatus      @default(Draft)
  listings    JobListing[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  vacancies   Vacancy[]

  @@map("jobs")
}

enum JobListingType {
  Qualification
  Responsibility

  @@map("job_listing_types")
}

model JobListing {
  id           String         @id @default(cuid())
  name         String
  type         JobListingType
  requirements String[]
  jobId        String
  job          Job            @relation(fields: [jobId], references: [id])

  @@map("job_listings")
}

enum VacancyStatus {
  Draft
  Published
  Unpublished

  @@map("vacancy_statuses")
}

model Vacancy {
  id              String         @id @default(cuid())
  profession      String
  roleType        String
  employment_type EmploymentType
  jobId           String
  job             Job            @relation(fields: [jobId], references: [id])
  status          JobStatus
  postedAt        DateTime       @default(now())
  deadline        DateTime

  @@map("vacancies")
}

enum AdminRole {
  Admin
  Director
  Manager

  @@map("admin_roles")
}

model Admin {
  id       String    @id @default(cuid())
  role     AdminRole
  staff_id String    @unique
  staff    Staff     @relation(fields: [staff_id], references: [id])

  @@map("admins")
}

model Staff {
  id            String   @id @default(cuid())
  title         String
  firstName     String
  lastName      String
  middleName    String?
  fullName      String
  email         String   @unique
  admin_details Admin?
  account_id    String   @unique
  account       User     @relation(fields: [account_id], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("staffs")
}
